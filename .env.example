# Copie pra .env e preencha com suas credenciais.
# Nunca commita o .env real — o .gitignore já exclui, mas fique atento.

# --- Banco de dados ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=meu_banco
DB_USER=backup_user
DB_PASSWORD=troca_essa_senha

# --- Diretório de backup ---
# precisa existir com permissão de escrita pro usuário que roda os scripts
BACKUP_DIR=/var/backups/postgresql

# --- Retenção ---
RETENTION_DAYS=30
MIN_BACKUPS_KEEP=3

# --- Opções ---
COMPRESS=true
DUMP_FORMAT=custom
PARALLEL_JOBS=2

# schemas/tabelas pra excluir do backup (separados por espaço, ou deixa vazio)
EXCLUDE_SCHEMAS=
EXCLUDE_TABLES=

# --- Alertas (deixa em branco pra desativar) ---
ALERT_EMAIL=
SLACK_WEBHOOK=

# --- Checksum ---
VERIFY_CHECKSUM=true
